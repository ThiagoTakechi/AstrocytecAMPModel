# Compiler
CXX = g++

# Compiler flags (-Wall enables all compiler's warning messages)
CXXFLAGS = -Wall -std=c++2a

# Target executable (No .exe extension needed on Linux)
TARGET = RunModel

# Source files (Headers removed from SRC list as they are not compiled directly)
SRC = Astrocyte.cpp StimuliGenerator.cpp Simulator.cpp RunModel.cpp 

# Object files (.o instead of .obj)
OBJ = Astrocyte.o StimuliGenerator.o Simulator.o RunModel.o

# Default rule: build the target
all: $(TARGET)

# Compile source files into object files
%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Link object files into the executable
$(TARGET): $(OBJ)
	$(CXX) $(CXXFLAGS) $(OBJ) -o $(TARGET)

# Clean build files
clean:
	rm -f $(OBJ) $(TARGET)
